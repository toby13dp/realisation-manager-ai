{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Realisation Manager AI",
  "version": "1.0.0",
  "identifier": "nl.marien.realisation-manager-ai",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Realisation Manager AI",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; media-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$DOCUMENT/**", "$PICTURES/**", "$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2026 Mariën Sanitair en Centrale Verwarming",
    "category": "Productivity",
    "shortDescription": "Lokale AI-media-organisatie",
    "longDescription": "Realisation Manager AI organiseert automatisch foto's en video's van sanitair- en CV-projecten met lokale AI-classificatie."
  },
  "plugins": {}
}
